# Pipeline mode: topics (default) = Google News + BBC supplements → master → brutalist email
# regions = legacy per-continent RSS + styled digest
PIPELINE_MODE=topics

# Phase 3 — slice (topics mode only): fewer topics = faster search + curation
# PIPELINE_SLICE=1
# PIPELINE_SLICE_TOPICS=tech
# PIPELINE_SLICE_TOPICS=tech,macro,geopolitics

# OpenAI — master curator (topics) and legacy ranker (regions)
OPENAI_API_KEY=
OPENAI_MASTER_MODEL=gpt-4o-mini
OPENAI_RANK_MODEL=gpt-4o-mini

# Topic pipeline caps
TOP_STORIES_PER_TOPIC=10
MAX_CANDIDATES_PER_TOPIC=80

# Email — see docs/RESEND.md for Resend step-by-step
# Resend: set RESEND_API_KEY. EMAIL_FROM must match a Resend-allowed sender (verified domain or their test sender).
EMAIL_FROM="Digest <onboarding@resend.dev>"
# Primary inbox for the digest (comma-separated for multiple recipients)
EMAIL_TO=jordanxavi95@gmail.com
# Optional — `npm run send:test` uses SEND_TEST_TO if set, otherwise EMAIL_TO
# SEND_TEST_TO=
EMAIL_SUBJECT=Globo News 24

# Resend — recommended. If unset, you must set SMTP_HOST (and usually SMTP_USER/SMTP_PASSWORD).
# The app no longer defaults to localhost:587 (that caused confusing ECONNREFUSED errors).
RESEND_API_KEY=

# Option B: SMTP (uncomment and fill all — do not leave SMTP_HOST set with empty USER/PASS)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_SECURE=false
# SMTP_REQUIRE_TLS=true

# Phase 1 — orchestrator (npm run orchestrate | run:scheduled)
# auto = only 9:00–9:18 & 17:30–17:48 America/New_York | force = bypass window | dry-run = log only
# ORCHESTRATE_MODE=auto
# SKIP_DEDUPE=1
# SEND_HISTORY_PATH=./data/send-history.json

# Phase 4 — run history, artifacts, structured logs (see docs/PHASE4_RUN_HISTORY.md)
# RUN_HISTORY=0
# RUN_HISTORY_PATH=./data/run-history.json
# RUN_HISTORY_MAX_RECORDS=500
# RUN_ARTIFACTS=1
# PIPELINE_LOG_FORMAT=json

# Phase 5 — agent registry and enabled state (see docs/PHASE5_AGENT_REGISTRY.md)
# AGENT_REGISTRY_PATH=./data/agent-registry.json
# AGENT_ENABLE=topic.search,topic.master_review,topic.compile,topic.resolve_links,delivery.email
# AGENT_DISABLE=topic.resolve_links

# Phase 6 — admin UI foundation
# ADMIN_PORT=8787
# ADMIN_SETTINGS_PATH=./data/admin-settings.json

# Phase 7 — stories + digests data stores
# STORY_HISTORY_MAX=5000
# DIGEST_HISTORY_MAX=1000

# Phase 8 — manual/dry/test send + safe operator controls
# SEND_MODE=live
# SEND_TEST_TO=you@example.com
# SEND_ALLOWLIST=example.com,you@example.com
# SEND_REQUIRE_CONFIRM=true
# SEND_CONFIRM=SEND

# Optional
# DIGEST_HTML_PATH=./output/digest.html
# DIGEST_TEXT_PATH=./output/digest.txt

# Bottom of digest — Reddit “hot” RSS (r/worldnews, r/artificial, r/economics, r/StockMarket) + this week’s earnings
# DIGEST_BOTTOM_SECTIONS=0   # set to 0 / false / no to disable
# REDDIT_POSTS_PER_SUB=6
# FMP_API_KEY=               # Financial Modeling Prep — free tier fills the earnings table (https://site.financialmodelingprep.com/)
# EARNINGS_CALENDAR_URL=https://finance.yahoo.com/calendar/earnings
# EARNINGS_YOUTUBE_URL=      # e.g. a channel, playlist, or search URL for earnings calls / recaps
