{
  "name": "global-news-pipeline",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "pipeline": "tsx scripts/runPipeline.ts",
    "pipeline:slice": "PIPELINE_SLICE=1 tsx scripts/runPipeline.ts",
    "send": "tsx scripts/sendEmail.ts",
    "send:dry-run": "SEND_MODE=dry-run tsx scripts/sendEmail.ts",
    "send:test": "SEND_MODE=test tsx scripts/sendEmail.ts",
    "pipeline:test": "tsx scripts/runPipeline.ts && SEND_MODE=test tsx scripts/sendEmail.ts",
    "admin": "tsx scripts/adminServer.ts",
    "orchestrate": "tsx scripts/orchestrate.ts",
    "run:all": "tsx scripts/runPipeline.ts && tsx scripts/sendEmail.ts",
    "run:scheduled": "tsx scripts/orchestrate.ts",
    "gha:secrets": "tsx scripts/syncGithubSecrets.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "luxon": "^3.5.0",
    "nodemailer": "^6.9.16",
    "openai": "^4.73.0",
    "resend": "^4.0.1",
    "rss-parser": "^3.13.0"
  },
  "devDependencies": {
    "@types/luxon": "^3.7.1",
    "@types/node": "^22.10.1",
    "@types/nodemailer": "^6.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
